NODE_ENV=development
PORT=3000

# Provider selection: mock | swiggy-mcp
DATA_PROVIDER=mock

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Swiggy MCP
SWIGGY_MCP_BASE_URL=
SWIGGY_MCP_API_KEY=
SWIGGY_MCP_CATALOG_PATH=/food/catalog
SWIGGY_MCP_TRENDING_PATH=/food/trending
SWIGGY_MCP_RESTAURANTS_PATH=/food/restaurants

